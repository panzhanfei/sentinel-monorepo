# 复制为 .env.development / .env.production 后填写；勿提交含真实密钥的文件
# 完整校验见 src/config/env.config.ts

NODE_ENV=development
PORT=4000

REDIS_URL=redis://127.0.0.1:6379
# DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/sentinel

# 与 Next BFF 一致；生产禁止使用仓库内置占位字符串（启动校验会失败）
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2024
REFRESH_TOKEN_SECRET=your-refresh-token-secret-different-from-jwt
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# 浏览器来源白名单，逗号分隔多个 Origin，须含协议，无尾斜杠
CORS_ORIGIN=http://localhost:3000

# 反代层数：仅 Caddy/Nginx 一层时生产可设 1，便于限流识别真实 IP
TRUST_PROXY_HOPS=0

# 请求体上限（express.json）
JSON_BODY_LIMIT=1mb

# 全局限流（Redis 存储，多 worker 共享计数）；设为 false 可关闭
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1

ANVIL_RPC_URL=http://127.0.0.1:8545
