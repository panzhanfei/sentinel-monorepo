generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id               String    @id @default(cuid())
  address          String    @unique // 钱包地址
  telegramChatId   String?   // Telegram 预警接收 Chat ID
  createdAt        DateTime  @default(now())
  jobs             Job[]
}

// 任务模型（核心：记录扫描状态与进度）
model Job {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // "SCAN_ERC20", "SCAN_SECURITY"
  status      String   // "PENDING", "RUNNING", "COMPLETED", "FAILED"
  progress    Int      @default(0) // 0-100
  result      Json?    // 扫描结果详情
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 全网黑名单
model Blacklist {
  id        String   @id @default(cuid())
  address   String   @unique
  reason    String
  level     String   // "HIGH", "MEDIUM", "LOW"
  addedAt   DateTime @default(now())
}

// 单表会话：threadId 即对外 sessionId；一条 agent=__thread__ 的锚点行承载原 ChatSession 的 userId/address
model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  address   String

  role      String   // "user" | "assistant" | "system"
  agent     String   // Scanner | Auditor | USER | __thread__ 等
  content   String   @db.Text
  status    String   // thinking | done | error

  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
  @@index([userId, createdAt])
}