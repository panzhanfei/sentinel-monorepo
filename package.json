{
  "name": "sentinel-monorepo",
  "private": true,
  "scripts": {
    "infra:up": "docker compose up -d",
    "infra:up:edge": "docker compose --profile edge up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "node:fork": "export $(grep -v '^#' .env | grep -v '^$' | xargs) && anvil --fork-url $QUICKNODE_RPC_URL --chain-id 31337",
    "start:demo": "pnpm run node:fork & sleep 5 && pnpm run dev",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 delete sentinel-api sentinel-next sentinel-sub-react sentinel-sub-vue",
    "pm2:logs": "pm2 logs"
  },
  "devDependencies": {
    "pm2": "^6.0.14",
    "prettier": "^3.7.4",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "wagmi": "3.4.1",
      "viem": "2.22.14",
      "zod": "^3.23.8",
      "ox": "0.11.1",
      "prisma": "6.2.1",
      "@prisma/client": "6.2.1"
    }
  },
  "dependencies": {
    "cross-env": "^10.1.0"
  }
}
