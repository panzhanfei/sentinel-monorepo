# Next.js 宿主（默认 PM2 sentinel-next 监听 3000）
{$SENTINEL_DOMAIN}, www.{$SENTINEL_DOMAIN} {
	encode gzip zstd

	handle /anvil-rpc/* {
		reverse_proxy {$CADDY_UPSTREAM_ANVIL:host.docker.internal:8545}
	}

	handle {
		reverse_proxy {$CADDY_UPSTREAM_NEXT:host.docker.internal:3000} {
			flush_interval -1
		}
	}
}
